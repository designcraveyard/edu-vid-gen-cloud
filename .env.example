# Edu Video Gen — Configuration
# Run /setup or double-click setup.sh (Mac) / setup.bat (Windows) to configure

# --- Google Cloud Project ---
GCLOUD_PROJECT=your-project-id

# --- Vertex AI Auth (Veo video gen, Imagen images) ---
# Drop service-account.json in the plugin root. No gcloud CLI needed.
GOOGLE_APPLICATION_CREDENTIALS=__PLUGIN_DIR__/service-account.json
GOOGLE_SERVICE_ACCOUNT_PATH=__PLUGIN_DIR__/service-account.json

# --- Google Workspace Auth (Drive, Docs, Sheets) ---
# OAuth2: credentials.json (pre-packaged) + token.json (generated on first sign-in)
GOOGLE_CREDENTIALS_PATH=__PLUGIN_DIR__/credentials.json
GOOGLE_TOKEN_PATH=__PLUGIN_DIR__/token.json

# --- Required: ElevenLabs ---
# Used for: voiceover generation (no alternative backend)
ELEVENLABS_API_KEY=sk_your_key_here

# --- Optional: Gemini API Key ---
# Fallback for image generation if not using Vertex AI
GEMINI_API_KEY=your_key_here

# --- Optional: Together AI ---
# Enables Wan 2.7 video backend (~33% cheaper than Veo)
TOGETHER_API_KEY=

# --- Output Directory ---
# Default: ~/Movies/EduVidGen (Mac) or ~/Videos/EduVidGen (Windows)
# Override per-video by saying "save this video in [path]" during generation
OUTPUT_BASE_DIR=

# --- Exchange Rate ---
USD_TO_INR=84.5
