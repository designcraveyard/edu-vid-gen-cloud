# Edu Video Gen — Configuration
# Run /setup to configure interactively (recommended)

# --- Primary Auth: Google Cloud / Vertex AI ---
# Required for: Veo video generation, Imagen 4 images, all validation scripts
# Set up via: gcloud auth application-default login
GCLOUD_PROJECT=your-project-id

# --- Required: ElevenLabs ---
# Used for: voiceover generation (no alternative backend)
ELEVENLABS_API_KEY=sk_your_key_here

# --- Optional Fallback: Gemini API Key ---
# Only needed if NOT using Vertex AI (Google Cloud) for image generation
# Used by: generate-image.mjs, generate-character-sheet.mjs, extend-image.mjs
GEMINI_API_KEY=your_key_here

# --- Optional: Together AI ---
# Enables Wan 2.7 video backend (~33% cheaper than Veo)
TOGETHER_API_KEY=your_key_here

# --- Output Directory ---
# Leave empty to use current working directory when running /edu-video
OUTPUT_BASE_DIR=

# --- Google Workspace (Drive, Docs, Sheets) ---
# Required for: cloud-native artifact storage, review workflow
# Set up via: /setup -> Google Workspace section
# credentials.json and token.json are stored in the plugin root directory
# No API key needed — uses OAuth2 Desktop App flow
GOOGLE_CREDENTIALS_PATH=__PLUGIN_DIR__/credentials.json
GOOGLE_TOKEN_PATH=__PLUGIN_DIR__/token.json

# --- Exchange Rate ---
# USD to INR conversion rate for cost tracking
USD_TO_INR=84.5
